{
  "name": "kitchen-sink",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#modules/*": "./app/modules/*",
    "#middleware/*": "./app/middleware/*",
    "#config/*": "./config/*",
    "#exceptions/*": "./app/exceptions/*",
    "#start/*": "./start/*"
  },
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register --watch bin/server.ts",
    "start": "node --import @swc-node/register/esm-register bin/server.ts",
    "test": "node --import @swc-node/register/esm-register $(node -p \"require.resolve('@c9up/helix/bin/helix.js')\") test tests/ --timeout=60000 --tsx=false --threads=1"
  },
  "dependencies": {
    "@c9up/archive": "workspace:*",
    "@c9up/atlas": "workspace:*",
    "@c9up/aurora": "workspace:*",
    "@c9up/bay": "workspace:*",
    "@c9up/blackhole": "workspace:*",
    "@c9up/chronos": "workspace:*",
    "@c9up/echo": "workspace:*",
    "@c9up/nova": "workspace:*",
    "@c9up/photon": "workspace:*",
    "@c9up/ream": "workspace:*",
    "@c9up/relay": "workspace:*",
    "@c9up/rosetta": "workspace:*",
    "@c9up/rover": "workspace:*",
    "@c9up/rune": "workspace:*",
    "@c9up/sigil": "workspace:*",
    "@c9up/spectrum": "workspace:*",
    "@c9up/warden": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@c9up/helix": "workspace:*",
    "@swc-node/register": "^1.11.1",
    "@types/node": "*",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}
